---
interface Props {
  name: string;
  desc: string;
  image: string;
}

const { name, desc, image } = Astro.props;
---

<div class="card">
  <img src={image} />
  <div class="tech-info">
    <p class="tech-name">{name}</p>
    <p class="tech-desc">{desc}</p>
  </div>
</div>

<style>
  .card {
    display: flex;
    width: 400px;
    margin-inline: auto;
    background-color: #20202b;
    color: #a9b1d6;
    border-radius: 10px;
    padding: 0.3rem 1rem;
  }
  .tech-info {
    padding: 1rem;
    line-height: 2rem;
  }
  .tech-name {
    font-size: 1.6rem;
    font-weight: bold;
  }
  img {
    height: 80px;
    margin: auto 0 auto 0;
  }

  @media (max-width: 480px) {
    .card {
      width: 450px;
    }
  }
</style>
