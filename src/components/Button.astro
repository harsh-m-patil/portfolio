---
interface Props {
  title: string;
  href: string;
}

const { href, title } = Astro.props;
---

<a href={href}>{title}</a>

<style>
  a {
    text-decoration: none;
    background-color: #7aa2f7;
    padding: 0.7rem;
    font-weight: bold;
    font-size: 1.2rem;
    color: #000000;
    border-radius: 0.8rem;
    cursor: pointer;
    margin: 1rem;
  }
</style>
