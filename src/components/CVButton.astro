---
interface Props {
  title: string;
  href: string;
}

const { href, title } = Astro.props;
---

<a href={href} target="_blank">{title}</a>

<style>
  a {
    text-decoration: none;
    padding: 0.7rem;
    font-weight: bold;
    font-size: 1.2rem;
    color: #7aa2f7;
    border: 1px solid #7aa2f7;
    border-radius: 0.8rem;
    cursor: pointer;
  }
</style>
