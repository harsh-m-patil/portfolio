---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import CVButton from "../components/CVButton.astro";
---

<Layout title="Harsh's Portfolio">
  <main>
    <div class="hero-container" id="hero">
      <h1>Hi I am <span class="text-blue">Harshwardhan</span></h1>
      <p>A full stack web developer and <br /> Computer Science Student</p>
      <div class="btn-container">
        <Button title="See My Work >" href="#projects" />
        <CVButton
          title="Download CV"
          href="https://drive.google.com/file/d/1dhH69-q5unSJd86YatTCyrtPk1c6IqC-/view?usp=drivesdk"
        />
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    height: 90vh;
    padding: 1rem;
    display: grid;
    place-items: center;
    color: white;
  }
  h1 {
    font-size: 4rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1rem;
  }
  .text-blue {
    color: #7aa2f7;
  }
  .hero-container {
    text-align: center;
    padding: 1rem;
  }
  .hero-container p {
    font-size: 1.7rem;
    color: #787c99;
    margin-bottom: 2rem;
  }
  .btn-container {
    padding: 1rem;
  }
</style>
