---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import CVButton from "../components/CVButton.astro";
---

<Layout title="Harsh's Portfolio">
  <main>
    <div class="hero-container" id="hero">
      <h1 class="fade-in">
        Hi I am <span class="text-blue slide-in">Harshwardhan</span>
      </h1>
      <p class="fade-in">
        A full stack web developer and <br /> Computer Science Student
      </p>
      <div class="btn-container fade-in">
        <Button title="See My Work >" href="#projects" />
        <CVButton
          title="Download CV"
          href="https://drive.google.com/file/d/1dhH69-q5unSJd86YatTCyrtPk1c6IqC-/view?usp=drivesdk"
        />
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    height: 90vh;
    padding: 1rem;
    display: grid;
    place-items: center;
    color: white;
    opacity: 0;
    animation: fadeIn 1.5s forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  .hero-container {
    text-align: center;
    padding: 1rem;
  }

  h1 {
    font-size: 4rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1rem;
    opacity: 0;
    transform: translateY(-20px);
    animation: slideIn 1s forwards 0.3s;
  }

  @keyframes slideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .text-blue {
    color: #7aa2f7;
  }

  .hero-container p {
    font-size: 1.7rem;
    color: #787c99;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(20px);
    animation: slideIn 1s forwards 0.5s;
  }

  .btn-container {
    padding: 1rem;
    opacity: 0;
    animation: fadeIn 1s forwards 0.7s;
  }

  Button,
  CVButton {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  Button:hover,
  CVButton:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }
</style>
